# TelePager server configuration — copy to .env and fill in.
# cp .env.example .env

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# polling (default, no public URL needed) | webhook (needs PUBLIC_URL below)
TELEGRAM_MODE=polling
PUBLIC_URL=
WEBHOOK_SECRET=

# ── Supabase (optional — see README "Notes/gotchas"; local-disk mode works
# without these, but the History long-press metadata overlay needs the DB) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=videos
SUPABASE_TABLE=videos

# ── Web server ────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ── Transcode / playback ──────────────────────────────────────────────────
FFMPEG_BIN=ffmpeg
VIDEO_SIZE=240
JPEG_QUALITY=5
STREAM_FPS=12

CACHE_DIR=storage
