# TelePager server configuration — copy to .env and fill in.
# cp .env.example .env

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# polling (default, no public URL needed) | webhook (needs PUBLIC_URL below)
TELEGRAM_MODE=polling
PUBLIC_URL=
WEBHOOK_SECRET=

# ── Web server ────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
# Must match SERVER_PORT in the firmware's include/config.h.
SERVER_PORT=8090

# ── Transcode / playback ──────────────────────────────────────────────────
FFMPEG_BIN=ffmpeg
VIDEO_SIZE=240
JPEG_QUALITY=5
STREAM_FPS=12

# Transcoded .mjpeg blobs + the SQLite metadata db both live here. Under Docker
# compose overrides this to /data (bind-mounted from ./storage).
CACHE_DIR=storage
DB_PATH=storage/telepager.db
